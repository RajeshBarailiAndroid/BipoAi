PORT=3001

# Option A: Gemini API keys (AIzaSy... from https://aistudio.google.com/apikey)
# Use up to 3 keys — if one is busy or rate-limited, the next is tried automatically.
# Preferred name (also accepts GEMINI_KEY, GOOGLE_API_KEY, GOOGLE_GENAI_API_KEY on the server)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_KEY_2=your-second-gemini-api-key
GEMINI_API_KEY_3=your-third-gemini-api-key
# Or comma-separated: GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-2.5-flash
GEMINI_SOLVE_MODEL=gemini-2.5-pro
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE_MALE=Charon
GEMINI_TTS_VOICE_FEMALE=Aoede

# Azure Document Intelligence — extract text from PDF, Word, images before Gemini
# Create resource: https://portal.azure.com → Document Intelligence
DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
DOCUMENT_INTELLIGENCE_API_KEY=your-azure-document-intelligence-key

# Option B: Service account JSON (Vertex AI) — use if AQ. keys don't work
# GEMINI_USE_VERTEX=true
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Google OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth client ID → Web)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://bipoai.com/api/auth/google/callback

# Apple Sign In (Apple Developer → Identifiers → Services ID)
APPLE_CLIENT_ID=com.yourcompany.bipai.web
APPLE_REDIRECT_URI=http://localhost:3001/signin.html

# Supabase (https://supabase.com/dashboard → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Required for email login (anon/public key — safe for auth on the server)
SUPABASE_ANON_KEY=your-anon-key
# Optional: route Google/Apple through Supabase OAuth (requires Supabase → Auth → Providers setup)
# Leave unset/false to use GOOGLE_CLIENT_ID/SECRET from .env directly (recommended to start)
SUPABASE_OAUTH_ENABLED=false
